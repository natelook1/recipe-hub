# Backend (backend/.env or environment variables)
API_KEY=dev-key                        # x-api-key for all API routes
GEMINI_API_KEY=your-gemini-api-key     # Google AI Studio key
PORT=3000                              # HTTP port (default: 3000)
DB_PATH=./data/recipe-hub.db          # SQLite database path
IMAGE_PATH=./data/images               # Uploaded image storage path

# In production these are read from Docker secrets:
#   /run/secrets/recipe_api_key  -> API_KEY
#   /run/secrets/gemini_api_key  -> GEMINI_API_KEY

# Frontend (frontend/.env.local)
VITE_API_URL=http://localhost:3000
VITE_API_KEY=dev-key
